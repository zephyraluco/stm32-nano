{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build (Debug)",
            "type": "shell",
            "command": "cmake --build ${workspaceFolder}/build/Debug",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Flash (OpenOCD)",
            "type": "shell",
            "command": "openocd -f stlink.cfg -f stm32f1x.cfg -c \"program build/Debug/stm32-nano.elf verify reset exit\"",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        }
    ]
}
